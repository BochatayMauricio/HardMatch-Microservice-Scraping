# Entorno de la aplicación
APP_ENV=development
APP_PORT=8000
APP_HOST=localhost

# IA - Google Gemini
GEMINI_API_KEY=API-KEY

# Configuración del Scraper
SCRAPER_TIMEOUT=15
MAX_RETRIES=3

# Configuración avanzada (opcional)
SCRAPER_TIMEOUT_SECONDS=20
SCRAPER_MAX_RETRIES=3
SCRAPER_MIN_DELAY_SECONDS=1.1
SCRAPER_MAX_DELAY_SECONDS=3.2
SCRAPER_BACKOFF_BASE_SECONDS=1.5
SCRAPER_BACKOFF_MAX_SECONDS=35
# Lista separada por comas. Ejemplo: http://user:pass@host1:port,http://host2:port
SCRAPER_PROXIES=